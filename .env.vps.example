# =============================================================================
# Public Form Logger — Production environment (.env.vps)
# =============================================================================
# Copy this file to `.env.vps` on the VPS (in /opt/public-form-logger/).
# This file is gitignored. DO NOT commit real secrets.

NODE_ENV=production
PORT=4001

# Mount the app under /logger so it's reachable behind ems-nginx
# at https://api.attendee.fr/logger/...
BASE_PATH=/logger

# --- Database (internal docker network) -------------------------------------
DATABASE_URL=postgresql://logger:CHANGE_ME@postgres:5432/public_form_logger?schema=public
POSTGRES_USER=logger
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=public_form_logger

# --- CORS (domains allowed to POST to /logger/v1/public-form-logs) ----------
# Bare domains match host AND any subdomain.
CORS_ORIGINS=https://attendee.fr,https://www.attendee.fr,choyou.fr,itforbusiness.fr

# --- Admin auth -------------------------------------------------------------
ADMIN_EMAIL=admin@attendee.fr
ADMIN_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=8h
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- Limits -----------------------------------------------------------------
RATE_LIMIT_PUBLIC_PER_IP=60
RATE_LIMIT_PUBLIC_PER_TOKEN=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15
HTTP_BODY_LIMIT_BYTES=102400
MAX_FORM_PAYLOAD_BYTES=32768
MAX_FORM_PAYLOAD_KEYS=100
TRUST_PROXY_HOPS=1

# --- Attendee API (used by admin UI to resolve event names) -----------------
ATTENDEE_API_BASE_URL=https://api.attendee.fr
ATTENDEE_EVENT_CACHE_TTL_SEC=3600
ATTENDEE_HTTP_TIMEOUT_MS=3000
