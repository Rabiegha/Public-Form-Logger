# =============================================================================
# Public Form Logger — Local environment (npm run start:dev, hors Docker)
# =============================================================================
# Copy this file to .env (which is gitignored).
# Use this when you run the app directly on your Mac (npm run start:dev),
# or when you run Prisma CLI commands from your host (migrate, studio, ...).

# --- App ---------------------------------------------------------------------
NODE_ENV=development
PORT=4001

# --- Database ----------------------------------------------------------------
# Logger uses port 5433 on the host to avoid clashing with Attendee back (5432).
# Inside Docker the port stays 5432 — see .env.docker.example.
DATABASE_URL=postgresql://logger:logger_dev_pwd@localhost:5433/public_form_logger?schema=public

# Postgres credentials (consumed by docker-compose to provision the DB)
POSTGRES_USER=logger
POSTGRES_PASSWORD=logger_dev_pwd
POSTGRES_DB=public_form_logger
POSTGRES_PORT_HOST=5433

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins. Bare domains are matched against
# host AND any subdomain (e.g. choyou.fr also allows www.choyou.fr).
# In dev keep localhost; in prod use real landing-page domains.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- Admin auth --------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!2026
JWT_SECRET=replace_with_a_long_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=8h
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Rate limits -------------------------------------------------------------
RATE_LIMIT_PUBLIC_PER_IP=60
RATE_LIMIT_PUBLIC_PER_TOKEN=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15

# --- Payload limits ----------------------------------------------------------
HTTP_BODY_LIMIT_BYTES=102400
MAX_FORM_PAYLOAD_BYTES=32768
MAX_FORM_PAYLOAD_KEYS=100

# --- Trust proxy -------------------------------------------------------------
# Set to the number of reverse proxies in front of the app (1 for nginx, etc.)
TRUST_PROXY_HOPS=1

# --- Attendee API ------------------------------------------------------------
ATTENDEE_API_BASE_URL=https://api.attendee.fr
ATTENDEE_EVENT_CACHE_TTL_SEC=3600
ATTENDEE_HTTP_TIMEOUT_MS=3000
