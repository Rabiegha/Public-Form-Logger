# =============================================================================
# Public Form Logger — Docker environment (docker-compose)
# =============================================================================
# Copy this file to .env.docker (which is gitignored).
# Used when the API runs INSIDE the docker-compose network.
# Difference vs .env: DATABASE_URL hostname is `postgres` (service name),
# port 5432 (container-internal), instead of localhost:5433.

# Defaults below target LOCAL DOCKER DEV (docker compose up --build).
# For production: set NODE_ENV=production, COOKIE_SECURE=true, real CORS domains,
# and a strong JWT_SECRET / POSTGRES_PASSWORD.

NODE_ENV=development
PORT=4001

# Connect to the `postgres` service in the same docker-compose network
DATABASE_URL=postgresql://logger:logger_dev_pwd@postgres:5432/public_form_logger?schema=public

POSTGRES_USER=logger
POSTGRES_PASSWORD=logger_dev_pwd
POSTGRES_DB=public_form_logger
POSTGRES_PORT_HOST=5433

# Local Docker dev: include localhost:4001 (admin UI on the host).
# In production replace with real landing-page domains only.
CORS_ORIGINS=http://localhost:4001,http://localhost:3000,http://localhost:5173,http://localhost:8080,choyou.fr,itforbusiness.fr

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!2026
JWT_SECRET=replace_with_a_long_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=8h
# COOKIE_SECURE=true requires HTTPS — keep false for local Docker dev,
# flip to true in production behind TLS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

RATE_LIMIT_PUBLIC_PER_IP=60
RATE_LIMIT_PUBLIC_PER_TOKEN=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15

HTTP_BODY_LIMIT_BYTES=102400
MAX_FORM_PAYLOAD_BYTES=32768
MAX_FORM_PAYLOAD_KEYS=100

TRUST_PROXY_HOPS=1
