<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= title %> · Public Form Logger</title>
<link rel="stylesheet" href="/admin/style.css" />
</head>
<body>
<header class="topbar">
  <a href="/admin/dashboard" class="brand">Public Form Logger</a>
  <nav>
    <% if (typeof user !== 'undefined' && user) { %>
      <span class="user"><%= user.email %></span>
      <form method="POST" action="/admin/auth/logout" class="inline-form" onsubmit="return doLogout(event)">
        <button type="submit" class="link-btn">Logout</button>
      </form>
    <% } %>
  </nav>
</header>
<main class="container">
