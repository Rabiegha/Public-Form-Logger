<% const title = 'Log ' + log.id.slice(0, 8); %>
<%- include('partials/header', { title, user }) %>

<a href="/admin/events/<%= encodeURIComponent(log.publicToken) %>" class="link-btn">← Retour à l'événement</a>

<header class="event-header">
  <div>
    <h2>Log <span class="mono small">#<%= log.id %></span></h2>
    <div class="muted small">
      Reçu le <%= new Date(log.createdAt).toLocaleString('fr-FR') %>
    </div>
    <div class="muted small">
      Événement : <strong><%= eventName || 'Sans nom' %></strong>
      <span class="mono">(<%= log.publicToken %>)</span>
    </div>
  </div>
</header>

<section class="detail-section">
  <h3>Champs du formulaire</h3>
  <% if (row.payloadKeys.length === 0) { %>
    <p class="muted small">Payload vide.</p>
  <% } else { %>
    <dl class="kv">
      <% row.payloadKeys.forEach((k) => { %>
        <dt><%= k %></dt>
        <dd><%= row.payloadValues[k] || '—' %></dd>
      <% }) %>
    </dl>
  <% } %>
</section>

<section class="detail-section">
  <h3>Métadonnées</h3>
  <dl class="kv">
    <dt>submission_id</dt><dd class="mono small"><%= log.submissionId || '—' %></dd>
    <dt>landing_page_url</dt><dd class="small"><%= log.landingPageUrl || '—' %></dd>
    <dt>referer</dt><dd class="small"><%= log.referer || '—' %></dd>
    <dt>user_agent</dt><dd class="small"><%= log.userAgent || '—' %></dd>
    <dt>ip_address</dt><dd class="mono small"><%= log.ipAddress || '—' %></dd>
    <dt>UTM source/medium/campaign</dt>
    <dd class="small">
      <%= [log.utmSource, log.utmMedium, log.utmCampaign].filter(Boolean).join(' / ') || '—' %>
    </dd>
    <dt>payload size</dt><dd><%= log.formPayloadSize %> B</dd>
  </dl>
</section>

<section class="detail-section">
  <h3>Payload JSON brut</h3>
  <pre class="json-block"><%= payloadJson %></pre>
</section>

<%- include('partials/footer') %>
