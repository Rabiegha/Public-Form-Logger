<% const title = 'Événements'; %>
<%- include('partials/header', { title, user }) %>

<section class="stats">
  <div class="stat"><div class="stat-label">Last 24h</div><div class="stat-value"><%= stats.last24h %></div></div>
  <div class="stat"><div class="stat-label">Last 7 days</div><div class="stat-value"><%= stats.last7d %></div></div>
  <div class="stat"><div class="stat-label">Last received</div>
    <div class="stat-value small">
      <%= stats.lastReceivedAt ? new Date(stats.lastReceivedAt).toLocaleString('fr-FR', { timeZone: 'Europe/Paris' }) : '—' %>
    </div>
  </div>
</section>

<h2 class="section-title">Événements</h2>

<form method="GET" action="<%= basePath %>/admin/events" class="filters filters-grid">
  <div class="field">
    <label for="f-q">Recherche</label>
    <input id="f-q" type="search" name="q" placeholder="Nom d'événement, public_token ou code…" value="<%= filters.q %>" />
  </div>
  <div class="field">
    <label for="f-from">Reçus depuis</label>
    <input id="f-from" type="date" name="from" value="<%= filters.from %>" />
  </div>
  <div class="field">
    <label for="f-to">Jusqu'au</label>
    <input id="f-to" type="date" name="to" value="<%= filters.to %>" />
  </div>
  <div class="field">
    <label for="f-size">Par page</label>
    <select id="f-size" name="pageSize">
      <% pageSizes.forEach((s) => { %>
        <option value="<%= s %>" <%= s === pageSize ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </div>
  <div class="field actions">
    <button type="submit">Filtrer</button>
    <a href="<%= basePath %>/admin/events" class="link-btn">Reset</a>
  </div>
</form>

<% if (items.length === 0) { %>
  <div class="empty-state">
    <% if (filters.q || filters.from || filters.to) { %>
      Aucun événement ne correspond à ces filtres.
    <% } else { %>
      Aucun log reçu pour l'instant.
    <% } %>
  </div>
<% } else { %>
  <ul class="event-grid">
    <% items.forEach((it) => { %>
      <li class="event-card">
        <a href="<%= basePath %>/admin/events/<%= encodeURIComponent(it.publicToken) %>" class="event-card-link">
          <div class="event-card-name">
            <%= it.eventName ? it.eventName : 'Événement sans nom' %>
            <% if (it.eventCode) { %><span class="badge"><%= it.eventCode %></span><% } %>
          </div>
          <div class="event-card-token mono small">
            <%= it.publicToken %>
          </div>
          <div class="event-card-meta">
            <span class="pill"><%= it.count %> log<%= it.count > 1 ? 's' : '' %></span>
            <span class="muted small">
              dernier : <%= new Date(it.lastReceivedAt).toLocaleString('fr-FR', { timeZone: 'Europe/Paris' }) %>
            </span>
          </div>
          <% if (it.eventStartAt) { %>
            <div class="event-card-dates muted small">
              <%= new Date(it.eventStartAt).toLocaleDateString('fr-FR', { timeZone: 'Europe/Paris' }) %>
              <% if (it.eventEndAt) { %>
                → <%= new Date(it.eventEndAt).toLocaleDateString('fr-FR', { timeZone: 'Europe/Paris' }) %>
              <% } %>
            </div>
          <% } else if (!it.eventName) { %>
            <div class="muted small">Nom indisponible (Attendee API).</div>
          <% } %>
        </a>
      </li>
    <% }) %>
  </ul>

  <%
    function buildUrl(p) {
      const params = new URLSearchParams();
      params.set('page', String(p));
      params.set('pageSize', String(pageSize));
      if (filters.q) params.set('q', filters.q);
      if (filters.from) params.set('from', filters.from);
      if (filters.to) params.set('to', filters.to);
      return '<%- basePath %>/admin/events?' + params.toString();
    }
  %>
  <%- include('partials/pagination', { page, totalPages, total, pageSize, buildUrl }) %>
<% } %>

<%- include('partials/footer') %>
